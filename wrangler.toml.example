name = "fishblog"
main = "src/index.ts"
compatibility_date = "2024-12-01"
compatibility_flags = ["nodejs_compat"]

[vars]
BLOG_TITLE = "FishBlog"
BLOG_DESCRIPTION = "A minimal blog on Cloudflare Workers"

# Secrets (set via Cloudflare Dashboard or `wrangler secret put`):
#   ADMIN_USERNAME  - admin login username
#   ADMIN_PASSWORD  - admin login password

[[d1_databases]]
binding = "DB"
database_name = "fishblog-db"
database_id = "placeholder-replace-after-creation"
