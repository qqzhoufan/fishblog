name = "fishblog"
main = "src/index.ts"
compatibility_date = "2024-12-01"
compatibility_flags = ["nodejs_compat"]

[vars]
BLOG_TITLE = "FishBlog"
BLOG_DESCRIPTION = "A minimal blog on Cloudflare Workers"
ADMIN_USERNAME = "admin"
# Change this before deploying! Generate with: openssl rand -hex 32
ADMIN_PASSWORD_HASH = ""

[[d1_databases]]
binding = "DB"
database_name = "fishblog-db"
database_id = "placeholder-replace-after-creation"
